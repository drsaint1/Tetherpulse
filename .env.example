# ============================================
# REQUIRED (4 keys minimum to run)
# ============================================

# Database — Supabase free tier: https://supabase.com
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres

# Telegram — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Google Gemini — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Seed encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WDK_SEED_ENCRYPTION_KEY=your_64_char_hex_key

# ============================================
# OPTIONAL — EVM testnets (defaults work)
# ============================================
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ============================================
# OPTIONAL — TON gasless (leave empty to skip)
# ============================================
# TON_CENTER_URL=https://testnet.toncenter.com/api/v3
# TON_CENTER_API_KEY=
# TON_API_URL=https://testnet.tonapi.io/v2
# TON_API_KEY=
# TON_PAYMASTER_ADDRESS=

# ============================================
# OPTIONAL — TRON gas-free (leave empty to skip)
# ============================================
# TRON_PROVIDER_URL=https://api.shasta.trongrid.io
# TRON_GASFREE_PROVIDER_URL=
# TRON_GASFREE_API_KEY=
# TRON_GASFREE_API_SECRET=
# TRON_SERVICE_PROVIDER=
# TRON_VERIFYING_CONTRACT=

# ============================================
# OPTIONAL — Server & rate limits
# ============================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# MAX_TIPS_PER_HOUR=20
# MAX_DAILY_AMOUNT_USD=500
# MIN_TIP_USDT=0.10
# MIN_TIP_XAUT=0.0001
# NEW_ACCOUNT_MAX_USD=10
# NEW_ACCOUNT_HOURS=24
